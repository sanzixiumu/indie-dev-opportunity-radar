page {
  background: #f6f7f9;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 32rpx 64rpx;
}

.eyebrow {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.title {
  margin-top: 14rpx;
  color: #111827;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 18rpx;
  color: #4b5563;
  font-size: 28rpx;
  line-height: 1.7;
}

.panel {
  margin-top: 32rpx;
  padding: 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #ffffff;
}

.panel-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.panel-text {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 24rpx;
  line-height: 1.4;
}
