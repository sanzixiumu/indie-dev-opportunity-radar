page {
  --app-bg: #faf8ff;
  --app-surface: #ffffff;
  --app-surface-low: #f2f3ff;
  --app-surface-container: #eaedff;
  --app-surface-high: #e2e7ff;
  --app-text: #131b2e;
  --app-text-subtle: #464554;
  --app-outline: #c7c4d7;
  --app-primary: #4648d4;
  --app-primary-container: #e1e0ff;
  --app-primary-text: #2f2ebe;
  --app-secondary: #0058be;
  --app-secondary-container: #d8e2ff;
  --app-tertiary: #904900;
  --app-shadow: rgba(15, 23, 42, 0.05);
  background: var(--app-bg);
  color: var(--app-text);
  font-family: Inter, -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  --td-brand-color: var(--app-primary);
  --td-primary-color-7: var(--app-primary);
  --td-brand-color-active: #2f2ebe;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 32rpx 64rpx;
}

.eyebrow {
  color: var(--app-primary);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: 0.04em;
}

.title {
  margin-top: 14rpx;
  color: var(--app-text);
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.25;
}

.subtitle {
  margin-top: 18rpx;
  color: var(--app-text-subtle);
  font-size: 28rpx;
  line-height: 1.6;
}

.panel {
  margin-top: 32rpx;
  padding: 28rpx;
  border: 1rpx solid var(--app-outline);
  border-radius: 16rpx;
  background: var(--app-surface);
}

.panel-title {
  color: var(--app-text);
  font-size: 30rpx;
  font-weight: 800;
}

.panel-text {
  margin-top: 12rpx;
  color: var(--app-text-subtle);
  font-size: 26rpx;
  line-height: 1.6;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.pill {
  padding: 8rpx 16rpx;
  border: 1rpx solid var(--app-outline);
  border-radius: 8rpx;
  background: var(--app-surface-low);
  color: var(--app-text);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.35;
}
