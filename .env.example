# =========================
# CloudBase / WeChat Mini Program
# =========================

# WeChat DevTools free development environment ID.
# Current Mini Program environment:
# cloud1-d8gh1a3icf3f03932
CLOUDBASE_ENV_ID=cloud1-d8gh1a3icf3f03932

# WeChat Mini Program AppID from project.config.json / WeChat DevTools.
WECHAT_MINI_APP_ID=wxf36d952b4427bb2f

# WeChat Mini Program AppSecret. Keep it server-side only.
WECHAT_MINI_APP_SECRET=


# =========================
# WeChat Pay
# =========================

# WeChat Pay merchant ID.
WECHAT_PAY_MCH_ID=

# WeChat Pay API v3 key.
WECHAT_PAY_API_V3_KEY=

# WeChat Pay merchant certificate serial number.
WECHAT_PAY_CERT_SERIAL_NO=

# Private key path for local or cloud function runtime.
WECHAT_PAY_PRIVATE_KEY_PATH=

# Payment callback URL.
WECHAT_PAY_NOTIFY_URL=


# =========================
# AI Providers
# =========================

# Default provider: deepseek / qwen / hunyuan / zhipu / openai
AI_PROVIDER=deepseek

# Default model name, for example deepseek-chat / qwen-plus.
AI_MODEL=

# OpenAI-compatible provider settings.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# DeepSeek.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen / DashScope OpenAI-compatible endpoint.
QWEN_API_KEY=
QWEN_BASE_URL=

# Tencent Hunyuan.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# Zhipu.
ZHIPU_API_KEY=


# =========================
# Market Data Providers
# =========================

APP_STORE_DATA_API_KEY=
ANDROID_MARKET_API_KEY=
MINIPROGRAM_DATA_API_KEY=
PRODUCT_HUNT_TOKEN=
CHROME_WEBSTORE_API_KEY=


# =========================
# Business Quotas and Pricing
# Prices are in cents.
# =========================

FREE_DAILY_RECOMMEND_LIMIT=3
FREE_FAVORITE_LIMIT=10
PRO_DAILY_RECOMMEND_LIMIT=20
PRO_MONTHLY_GENERATE_LIMIT=20
DEEP_MONTHLY_GENERATE_LIMIT=100

PRICE_DEEP_REPORT=990
PRICE_FULL_PRD=1990
PRICE_COMPARE_REPORT=1990
PRICE_PRO_YEARLY=19900


# =========================
# Runtime and Security
# =========================

NODE_ENV=development
INTERNAL_API_SECRET=
LOG_LEVEL=info
