.find-page {
  min-height: 100vh;
  padding-bottom: 96rpx;
  background: #f0fdfa;
}

.hero {
  text-align: center;
  margin: 18rpx 0 34rpx;
}

.hero-title {
  margin: 0;
  color: #134e4a;
  font-size: 60rpx;
  font-weight: 900;
  line-height: 1.12;
  text-align: center;
}

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.55;
  text-align: center;
}

.prompt-panel {
  padding: 12rpx;
  border: 1rpx solid #99f6e4;
  border-radius: 28rpx;
  background: #ffffff;
}

.idea-card {
  padding: 0;
  border: 1rpx solid #dbeafe;
  border-radius: 22rpx;
  overflow: hidden;
  background: #f8fafc;
}

.section {
  margin-top: 40rpx;
}

.section-title {
  margin-bottom: 20rpx;
  color: #134e4a;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.25;
}

.example-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
  width: 100%;
  overflow: hidden;
}

.example-chip {
  display: flex;
  width: 100%;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  min-width: 0;
  padding: 18rpx 20rpx;
  --td-tag-small-font: 28rpx / 28rpx var(--td-font-family, PingFang SC, Microsoft YaHei, Arial Regular);
  --td-tag-small-padding: 18rpx 20rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
  overflow: hidden;
  text-align: center;
}

.example-text {
  display: block;
  width: 100%;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.recent-card {
  margin-top: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #ccfbf1;
  border-radius: 18rpx;
  background: #ffffff;
}

.recent-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.recent-text,
.ai-note {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.recent-text {
  margin-top: 8rpx;
}

.recent-meta {
  margin-top: 10rpx;
  color: #9ca3af;
  font-size: 22rpx;
}

.ai-note-wrap {
  margin-top: 14rpx;
}

.ai-note-wrap {
  text-align: center;
}

.ai-note {
  display: block;
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1.5;
}

.empty-state {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx;
  border: 1rpx dashed #cbd5e1;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.65);
}

.empty-text {
  display: block;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.5;
}

.incubation-modal {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  flex-direction: column;
  background: #f6f7f9;
  animation: slideUp 180ms ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }

  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: grid;
  grid-template-columns: 88rpx 1fr 88rpx;
  align-items: center;
  padding: 28rpx 24rpx 20rpx;
  border-bottom: 1rpx solid #e5e7eb;
  background: #ffffff;
}

.modal-title-wrap {
  text-align: center;
}

.modal-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}

.modal-stage {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  color: #0f766e;
  font-size: 24rpx;
}

.modal-body {
  flex: 1;
  min-height: 0;
  padding: 28rpx;
  box-sizing: border-box;
}

.idea-edit-card,
.question-card,
.progress-card,
.result-card {
  padding: 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #ffffff;
}

.idea-edit-card {
  margin-bottom: 20rpx;
}

.idea-edit-title {
  margin-bottom: 14rpx;
  color: #111827;
  font-size: 26rpx;
  font-weight: 800;
}

.modal-idea-input {
  min-height: 120rpx;
}

.question-title,
.result-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.question-desc {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
  overflow-wrap: anywhere;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 26rpx;
}

.option-item {
  min-height: 72rpx;
  padding: 18rpx 22rpx;
  box-sizing: border-box;
  white-space: normal;
  overflow-wrap: anywhere;
}

.custom-input {
  margin-top: 24rpx;
}

.progress-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
}

.progress-dot {
  display: flex;
  flex: 0 0 42rpx;
  width: 42rpx;
  height: 42rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  color: #ffffff;
}

.progress-dot.active {
  border-color: #0f766e;
  background: #ccfbf1;
}

.progress-dot.done {
  border-color: #0f766e;
  background: #0f766e;
}

.progress-text {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.result-section {
  margin-top: 28rpx;
}

.result-heading {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.result-text,
.product-text,
.bullet-line,
.risk-desc,
.risk-source {
  margin-top: 10rpx;
  color: #4b5563;
  font-size: 25rpx;
  line-height: 1.6;
  white-space: normal;
  overflow-wrap: anywhere;
}

.product-row,
.risk-row {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f9fafb;
}

.product-name {
  color: #111827;
  font-size: 27rpx;
  font-weight: 800;
  overflow-wrap: anywhere;
}

.risk-source {
  color: #9a3412;
}

.modal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 18rpx 24rpx 34rpx;
  border-top: 1rpx solid #e5e7eb;
  background: #ffffff;
}

.secondary-button {
  flex: 1 1 180rpx;
  min-width: 0;
}

.action-primary {
  flex: 1.4 1 220rpx;
  min-width: 0;
}
