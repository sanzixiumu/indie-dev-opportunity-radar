.workspace-page {
  padding-bottom: 96rpx;
  background: #faf8ff;
  --td-brand-color: #4648d4;
  --td-primary-color-7: #4648d4;
  --td-brand-color-active: #2f2ebe;
}

.project-card,
.empty-wrap {
  margin-top: 28rpx;
  padding: 28rpx;
  border: 1rpx solid #c7c4d7;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.project-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.project-title,
.detail-project-title {
  min-width: 0;
  color: #131b2e;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.project-text,
.detail-text,
.product-text,
.bullet-line,
.risk-desc,
.risk-source {
  margin-top: 10rpx;
  color: #464554;
  font-size: 25rpx;
  line-height: 1.6;
  white-space: normal;
  overflow-wrap: anywhere;
}

.entry-text {
  color: #0058be;
  font-weight: 600;
}

.project-meta {
  margin-top: 12rpx;
  color: #767586;
  font-size: 22rpx;
  line-height: 1.5;
}

.project-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.project-action {
  flex: 1 1 150rpx;
  min-width: 0;
}

.prd-action {
  flex-basis: 180rpx;
}

.detail-modal {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #faf8ff;
  --td-brand-color: #4648d4;
  --td-primary-color-7: #4648d4;
  --td-brand-color-active: #2f2ebe;
}

.detail-header {
  display: grid;
  grid-template-columns: 88rpx 1fr 88rpx;
  align-items: center;
  padding: 28rpx 24rpx 20rpx;
  border-bottom: 1rpx solid #c7c4d7;
  background: #ffffff;
}

.detail-title {
  color: #131b2e;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
}

.detail-body {
  flex: 1;
  min-height: 0;
  padding: 28rpx;
  box-sizing: border-box;
}

.detail-card {
  padding: 28rpx;
  border: 1rpx solid #c7c4d7;
  border-radius: 16rpx;
  background: #ffffff;
}

.detail-project-title {
  font-size: 34rpx;
}

.detail-section {
  margin-top: 28rpx;
}

.detail-heading {
  color: #131b2e;
  font-size: 28rpx;
  font-weight: 800;
}

.product-row,
.risk-row {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f2f3ff;
}

.product-name {
  color: #131b2e;
  font-size: 27rpx;
  font-weight: 800;
  overflow-wrap: anywhere;
}

.risk-source {
  color: #904900;
}
